# .env.example

# ======================
# DEEPFAKE-GUARD Environment Configuration
# ======================

# Security Configurations
SECRET_KEY=your_secret_key_here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your_domain.com

# API Keys
API_KEY=your_api_key_here
ANOTHER_API_KEY=your_another_api_key_here

# Database Credentials
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DB_NAME

# CORS Settings
CORS_ORIGIN_WHITELIST=http://localhost:3000,http://your_domain.com

# Rate Limiting 
RATE_LIMIT=100/hour

# Authentication Settings
JWT_SECRET=your_jwt_secret_here

# Encryption Keys
ENCRYPTION_KEY=your_encryption_key_here

# Security Warnings
# 1. Do not share your .env file publicly.
# 2. Change all keys before deploying your application.
# 3. Regularly rotate your API keys and secrets.
# 4. Ensure your database credentials are protected.